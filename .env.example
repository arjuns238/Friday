# === Required for Phase 0 ===
DEEPGRAM_API_KEY=your_deepgram_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# === Required for Phase 3 ===
GOOGLE_API_KEY=your_google_api_key_here
# Note: Gmail OAuth2 creds are set up separately via `python -m friday setup-gmail`
# Stored at ~/.friday/google_creds.json after first run

# === Optional ===
TAVILY_API_KEY=your_tavily_api_key_here

# === Config overrides (optional) ===
# FRIDAY_HOTKEY=cmd+option+space
# FRIDAY_VOICE_ID=21m00Tcm4TlvDq8ikWAM   # ElevenLabs voice ID
# FRIDAY_VAD_AGGRESSIVENESS=2              # 0-3, higher = more aggressive silence detection
# FRIDAY_VAD_TRAILING_SILENCE_MS=500       # ms of silence before stopping recording
# FRIDAY_SCREENSHOT_MAX_KB=400             # max screenshot size sent to GPT-4o
# FRIDAY_LOG_LEVEL=INFO
