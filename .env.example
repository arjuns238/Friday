# === LLM provider (default: gemini) =========================================
# Options: gemini | openai | claude
FRIDAY_LLM=gemini

# Gemini 3.1 Flash Lite (default) — get key at aistudio.google.com
GOOGLE_API_KEY=your_google_api_key_here

# GPT-4o (set FRIDAY_LLM=openai to use)
OPENAI_API_KEY=your_openai_api_key_here

# Claude Haiku (set FRIDAY_LLM=claude to use)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# === Always required =========================================================
DEEPGRAM_API_KEY=your_deepgram_api_key_here
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# === Optional ================================================================
TAVILY_API_KEY=your_tavily_api_key_here

# Dev menu (rumps “Dev” submenu with proactive trigger simulations). true | false
# FRIDAY_DEV_MODE=false

# === Config overrides ========================================================
# FRIDAY_MUTE_KEY=ctrl+m
# FRIDAY_VOICE_ID=cgSgspJ2msm6clMCkdW9   # Jessica — peer
# FRIDAY_VAD_THRESHOLD=600                 # RMS energy threshold (raise for noisy mics)
# FRIDAY_VAD_ONSET_FRAMES=5                # ~150ms to confirm speech onset
# FRIDAY_VAD_OFFSET_FRAMES=25              # ~750ms of silence to end segment
# FRIDAY_BARGE_WEBRTC_VAD=1                # barge-in onset: 1=WebRTC VAD + energy (helps vs rustle; taps need below too)
# FRIDAY_BARGE_VAD_AGGRESSIVENESS=3        # 0=lenient … 3=strict (recommended 3 if taps still barge)
# FRIDAY_BARGE_ONSET_FRAMES=6            # consecutive ~30ms frames (~180ms) before TTS stops; raise if taps slip through
# FRIDAY_BARGE_IMPULSE_REJECT=1          # reject tap/clack-shaped energy even when WebRTC says “speech”
# FRIDAY_SCREENSHOT_MAX_KB=400             # max screenshot size sent to LLM
# FRIDAY_MEMORY_MAX_CHARS=8000             # max chars of memory injected into system prompt
# FRIDAY_LOG_LEVEL=INFO

# === Ambient / proactive context =============================================
# FRIDAY_AMBIENT_INTERVAL=60               # seconds between background screenshots
# FRIDAY_TRIGGER_INTERVAL=300              # seconds between proactive “should I speak?” checks
# FRIDAY_SESSION_LOG_MAX=60                # raw entries before compression is forced
# FRIDAY_COMPRESS_INTERVAL=900             # seconds between compression passes (daily session file)
# Raw screen rows append to ~/.friday/sessions/session_log.json (one JSON per line, never truncated).
# Compression only trims the in-memory window; daily prose goes to ~/.friday/sessions/YYYY-MM-DD.md
# Each app run also writes ~/.friday/sessions/<session-id>.jsonl — one JSON per reactive turn (user + friday).

# === File search (optional) ==================================================
# If set, the LLM uses this directory when the user says "search my project" without a path.
# Install ripgrep (`brew install ripgrep`) for faster search; otherwise a Python fallback is used.
# FRIDAY_FILE_SEARCH_DEFAULT_ROOT=/Users/you/Projects/my-repo
