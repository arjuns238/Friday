# === LLM provider (default: gemini) =========================================
# Options: gemini | openai | claude
FRIDAY_LLM=gemini

# Gemini 2.0 Flash (default) — get key at aistudio.google.com
GOOGLE_API_KEY=your_google_api_key_here

# GPT-4o (set FRIDAY_LLM=openai to use)
OPENAI_API_KEY=your_openai_api_key_here

# Claude Haiku (set FRIDAY_LLM=claude to use)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# === Always required =========================================================
DEEPGRAM_API_KEY=your_deepgram_api_key_here
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# === Gmail (Phase 3) =========================================================
# OAuth2 creds set up via `friday setup-gmail` — stored at ~/.friday/google_creds.json
# GOOGLE_API_KEY above is also used for Gemini email drafting

# === Optional ================================================================
TAVILY_API_KEY=your_tavily_api_key_here

# === Claude Code Agent =======================================================
# Default project dir when Friday can't infer it from context (e.g. screenshot)
# CLAUDE_DEFAULT_PROJECT_DIR=/Users/you/Projects/myapp
# Permission mode: default | acceptEdits | plan | bypassPermissions
# CLAUDE_PERMISSION_MODE=acceptEdits

# === Config overrides ========================================================
# FRIDAY_HOTKEY=cmd+option+space
FRIDAY_VOICE_ID=Xb7hH8MSUJpSji8lGJ0ZLrpJ5KY4NwOdbSDYk0k2   # Alice — Clear, Engaging Educator
# FRIDAY_VAD_AGGRESSIVENESS=2              # 0-3, higher = more aggressive silence detection
# FRIDAY_VAD_TRAILING_SILENCE_MS=700       # ms of trailing silence before stopping
# FRIDAY_SCREENSHOT_MAX_KB=400             # max screenshot size sent to LLM
# FRIDAY_LOG_LEVEL=INFO
