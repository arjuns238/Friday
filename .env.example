# === Always required =========================================================
# Orchestrator: Claude Haiku 4.5 (native Anthropic API)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# Subagents: Gemini Flash Lite via Google's OpenAI-compatible endpoint
GOOGLE_API_KEY=your_google_api_key_here
DEEPGRAM_API_KEY=your_deepgram_api_key_here
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# === Gmail ====================================================================
# OAuth2 creds set up via `friday setup-gmail` — stored at ~/.friday/google_creds.json
# GOOGLE_API_KEY above is also used for Gemini email drafting

# === Optional ================================================================
TAVILY_API_KEY=your_tavily_api_key_here

# === Config overrides ========================================================
# FRIDAY_HOTKEY=cmd+option+space
FRIDAY_VOICE_ID=Xb7hH8MSUJpSji8lGJ0ZLrpJ5KY4NwOdbSDYk0k2   # Alice — Clear, Engaging Educator
